{
  "name": "b3hub",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm run start:dev --workspace=apps/backend",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:mobile": "npm run start --workspace=apps/mobile",
    "dev:simulator": "cd apps/mobile && npx expo start --clear --go",
    "dev": "concurrently --names \"backend,web,mobile\" --prefix-colors \"blue,green,magenta\" \"npm run dev:backend\" \"npm run dev:web\" \"npm run dev:simulator\"",
    "build:backend": "npm run build --workspace=apps/backend",
    "build:web": "npm run build --workspace=apps/web",
    "build:mobile": "npm run build --workspace=apps/mobile",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "send:notif": "node scripts/send-test-notification.mjs",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "docs:generate": "node scripts/generate-instructions.mjs",
    "postinstall": "patch-package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "concurrently": "^9.2.1",
    "patch-package": "^8.0.1",
    "prettier": "^3.2.4",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "dependencies": {
    "expo": "~54.0.33",
    "hoist-non-react-statics": "^3.3.2",
    "memoize-one": "^5.2.1",
    "react": "19.1.0",
    "react-native": "0.81.5"
  }
}
