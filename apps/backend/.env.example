# B3Hub Backend - environment variables
# Copy this file to .env and fill in real values.
# NEVER commit .env with real secrets.

# App
NODE_ENV=development
PORT=3000
ALLOWED_ORIGIN=http://localhost:3001

# Database (Supabase PostgreSQL)
# Get from: Supabase -> Settings -> Database -> Connection string
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Auth (Supabase JWT)
# Get from: Supabase -> Settings -> API -> JWT Secret
JWT_SECRET=your-jwt-secret-here

# Supabase Storage
# Get from: Supabase -> Settings -> API
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# Email (Resend)
# Get from: https://resend.com/api-keys
# If absent, emails are logged to console only (safe for local dev)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@b3hub.lv
WEB_URL=https://app.b3hub.lv

# Stripe
# Get from: https://dashboard.stripe.com/apikeys
# Use sk_test_* for development, sk_live_* for production
STRIPE_SECRET_KEY=sk_test_...
# Get from: Stripe dashboard -> Developers -> Webhooks -> endpoint -> Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Google Maps (server-side only)
# Restrict to Routes API + Geocoding API by server IP
# Get from: https://console.cloud.google.com/google/maps-apis/credentials
GOOGLE_MAPS_SERVER_API_KEY=

# Sentry (error monitoring)
# Get from: https://sentry.io -> your project -> Settings -> Client Keys
# If absent, errors are only logged to console
SENTRY_DSN=

