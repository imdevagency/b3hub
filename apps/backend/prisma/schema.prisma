// B3Hub Construction Marketplace Platform - Prisma Schema
// After ANY change to this file run: npm run prisma:generate
// (that also regenerates .github/instructions/backend-schema.instructions.md)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ================================
// ENUMS
// ================================

enum UserType {
  BUYER // Demand side — anyone who orders materials or waste collection
  ADMIN // Platform administrators
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum CompanyType {
  CONSTRUCTION // Construction company
  SUPPLIER // Material supplier
  RECYCLER // Waste management
  CARRIER // Transport company
}

enum CompanyFeature {
  CONSTRUCTION_MANAGEMENT // Project management, budgets, DPRs, estimating (B3 Construction SaaS)
  RECYCLING_MANAGEMENT // Facility intake, APUS submissions, waste certificates (B3 Recycling SaaS)
}

enum CompanyRole {
  OWNER // Company admin — manages team, settings, billing
  MANAGER // Can manage jobs, orders, and assign drivers
  DRIVER // Can only see and execute transport jobs
  MEMBER // Default — read-only access
}

enum MaterialCategory {
  SAND
  GRAVEL
  STONE
  CONCRETE
  SOIL
  RECYCLED_CONCRETE
  RECYCLED_SOIL
  ASPHALT
  CLAY
  OTHER
}

enum MaterialUnit {
  TONNE
  M3
  PIECE
  LOAD
}

enum ContainerType {
  SKIP // Open top container
  ROLL_OFF // Roll-off dumpster
  COMPACTOR // Compactor container
  ENCLOSED // Enclosed container
}

enum ContainerSize {
  SMALL_3M3
  MEDIUM_5M3
  LARGE_7M3
  XLARGE_10M3
  XXLARGE_15M3
  XXXLARGE_20M3
}

enum ContainerStatus {
  AVAILABLE
  RENTED
  IN_TRANSIT
  MAINTENANCE
  RETIRED
}

enum OrderType {
  MATERIAL // Material purchase
  CONTAINER // Container rental
  DISPOSAL // Waste disposal
  TRANSPORT // Transport only
  COMBINED // Multiple services
}

enum OrderStatus {
  DRAFT
  PENDING
  CONFIRMED
  IN_PROGRESS
  DELIVERED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED // Funds held
  CAPTURED // Funds taken (on job start)
  RELEASED // Funds transferred to seller (on completion)
  PAID // Legacy/Direct
  PARTIALLY_PAID
  REFUNDED
  FAILED
}

enum PaymentMethod {
  CARD    // Card payment via Paysera Checkout
  INVOICE // NET terms — buyer pays via bank transfer or Paysera payment link
  SEPA    // SEPA Direct Debit via Paysera (for approved B2B buyers)
}

enum WastePurpose {
  CONSTRUCTION_WASTE
  DEMOLITION_WASTE
  EXCAVATION_SOIL
  MIXED_WASTE
  RECYCLABLE_MATERIALS
  HAZARDOUS_WASTE
  GREEN_WASTE
  OTHER
}

enum ApusStatus {
  NOT_REQUIRED  // non-licensed field or waste type outside APUS scope
  PENDING       // awaiting submission to VVD APUS
  SUBMITTED     // submitted to VVD APUS, awaiting acceptance
  ACCEPTED      // VVD confirmed the movement
  REJECTED      // VVD rejected — see apusNote
}

enum WasteType {
  CONCRETE
  BRICK
  WOOD
  METAL
  PLASTIC
  SOIL
  MIXED
  HAZARDOUS
}

// ── Skip Hire (public 4-step wizard) ──────────────────────────
enum SkipWasteCategory {
  MIXED
  GREEN_GARDEN
  CONCRETE_RUBBLE
  WOOD
  METAL_SCRAP
  ELECTRONICS_WEEE
}

enum SkipCategory {
  SKIP      // traditional open-top skip
  BIG_BAG   // 1 m³ bulk bag
  CONTAINER // enclosed roll-on/roll-off
}

enum SkipHireStatus {
  PENDING
  CONFIRMED
  DELIVERED
  COLLECTED
  COMPLETED
  CANCELLED
}

enum ContainerOrderStatus {
  SCHEDULED
  DELIVERED
  IN_USE
  PICKED_UP
  COMPLETED
  CANCELLED
}

enum TransportJobType {
  MATERIAL_DELIVERY
  CONTAINER_DELIVERY
  CONTAINER_PICKUP
  WASTE_COLLECTION
  EQUIPMENT_TRANSPORT
  TRANSPORT // General point-to-point freight transport
}

enum TransportJobStatus {
  AVAILABLE // Available for assignment
  ASSIGNED // Assigned to carrier
  ACCEPTED // Accepted by driver
  EN_ROUTE_PICKUP // On the way to pickup
  AT_PICKUP // At pickup location
  LOADED // Cargo loaded
  EN_ROUTE_DELIVERY // On the way to delivery
  AT_DELIVERY // At delivery location
  DELIVERED // Completed
  CANCELLED // Cancelled
  DELIVERY_REFUSED // Buyer/site refused to accept delivery at the door
}

enum TransportExceptionType {
  DRIVER_NO_SHOW
  SUPPLIER_NOT_READY
  WRONG_MATERIAL
  PARTIAL_DELIVERY
  REJECTED_DELIVERY
  SITE_CLOSED
  OVERWEIGHT
  OTHER
}

enum TransportExceptionStatus {
  OPEN
  RESOLVED
}

enum VehicleType {
  DUMP_TRUCK
  FLATBED_TRUCK
  SEMI_TRAILER
  HOOK_LIFT
  SKIP_LOADER
  TANKER
  VAN
}

enum VehicleStatus {
  ACTIVE
  IN_USE
  MAINTENANCE
  INACTIVE
}

enum NotificationType {
  ORDER_CREATED
  ORDER_CONFIRMED
  ORDER_CANCELLED
  ORDER_DELIVERED
  TRANSPORT_ASSIGNED
  TRANSPORT_STARTED
  TRANSPORT_COMPLETED
  PAYMENT_RECEIVED
  QUOTE_RECEIVED
  QUOTE_ACCEPTED
  SYSTEM_ALERT
  DOCUMENT_EXPIRING_SOON
  DRIVER_NEARBY
  WEIGHING_SLIP
  PAYOUT_PENDING         // carrier needs to provide IBAN for payouts
}

enum QuoteRequestStatus {
  PENDING
  QUOTED
  ACCEPTED
  CANCELLED
  EXPIRED
}

enum FrameworkContractStatus {
  DRAFT
  ACTIVE
  COMPLETED
  EXPIRED
  CANCELLED
}

enum FieldPassStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  COMPLETED
  ON_HOLD
}

enum FrameworkPositionType {
  MATERIAL_DELIVERY
  WASTE_DISPOSAL
  FREIGHT_TRANSPORT
}

enum QuoteResponseStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

enum SurchargeType {
  FUEL          // Fuel levy
  WAITING_TIME  // Truck waiting at loading/unloading site
  WEEKEND       // Weekend / public holiday delivery
  OVERWEIGHT    // Cargo exceeds standard weight limit
  NARROW_ACCESS // Restricted site access (pump required, crane etc.)
  REMOTE_AREA   // Out-of-zone delivery surcharge
  TOLL          // Road toll pass-through
  OTHER         // Catch-all
}

// ================================
// PAYMENTS
// ================================

model Payment {
  id      String @id @default(uuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id])

  payseraOrderId  String? // Paysera order UUID
  payseraPaymentUrl String? // Checkout redirect URL for buyer

  amount   Float // Total amount charged to buyer
  currency String @default("EUR")

  status PaymentStatus @default(PENDING)

  platformFee  Float? // B3Hub margin / revenue retained
  sellerPayout Float? // Amount owed to supplier(s) — recorded when payment RELEASED, paid out later via SupplierPayout
  driverPayout Float? // Amount owed to carrier/driver — recorded when payment RELEASED, paid out later via CarrierPayout

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Principal Payout Models ───────────────────────────────────────────────────
// B3Hub operates as principal: buyer pays B3Hub in full; B3Hub settles with
// suppliers and carriers separately on agreed payment terms (default NET-30).
// These models replace immediate Stripe Connect transfers — funds stay in
// B3Hub's platform account until the payout is explicitly executed by admin.

enum PayoutStatus {
  PENDING    // Obligation recorded; awaiting settlement batch
  PROCESSING // Paysera transfer initiated, awaiting confirmation
  PAID       // Transfer confirmed paid
  FAILED     // Transfer failed — manual action required
  CANCELLED  // Order cancelled/refunded; obligation voided
}

model SupplierPayout {
  id         String  @id @default(cuid())
  order      Order   @relation("OrderSupplierPayouts", fields: [orderId], references: [id])
  orderId    String
  supplier   Company @relation("SupplierPayouts", fields: [supplierId], references: [id])
  supplierId String

  amount   Float
  currency String @default("EUR")

  status    PayoutStatus @default(PENDING)
  dueDate   DateTime     // NET-30 from order completion date
  paidAt    DateTime?

  payseraTransferId String? // Populated when IBAN transfer is executed via Paysera Transfer API
  notes             String? // Free text — e.g. reason for manual override

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([supplierId])
  @@index([status])
  @@index([dueDate])
  @@map("supplier_payouts")
}

model CarrierPayout {
  id        String        @id @default(cuid())
  order     Order?        @relation("OrderCarrierPayouts", fields: [orderId], references: [id])
  orderId   String?
  job       TransportJob? @relation("JobCarrierPayout", fields: [jobId], references: [id])
  jobId     String?       @unique
  driver    User?         @relation("DriverPayouts", fields: [driverId], references: [id])
  driverId  String?
  carrier   Company?      @relation("CarrierPayouts", fields: [carrierId], references: [id])
  carrierId String?

  amount   Float
  currency String @default("EUR")

  status    PayoutStatus @default(PENDING)
  dueDate   DateTime     // NET-30 from order completion date
  paidAt    DateTime?

  payseraTransferId String? // Populated when IBAN transfer is executed via Paysera Transfer API
  notes             String? // Free text — e.g. reason for manual override

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([carrierId])
  @@index([driverId])
  @@index([status])
  @@index([dueDate])
  @@map("carrier_payouts")
}

model User {
  id                 String       @id @default(cuid())
  email              String?      @unique // optional: phone-only registration
  phone              String?      @unique // optional: email-only registration
  password           String?   // Hashed; null for phone-only accounts
  firstName          String
  lastName           String
  avatar             String?
  userType           UserType     @default(BUYER)
  isCompany          Boolean      @default(false) // true = company account (VAT invoices etc.)
  personalCode       String?      @unique // Latvian personal ID code (personas kods) — individuals only
  canSell            Boolean      @default(false) // approved to list & sell materials
  canTransport       Boolean      @default(false) // approved to offer transport services
  canSkipHire        Boolean      @default(false) // approved to manage skip hire fleet
  canRecycle         Boolean      @default(false) // approved to operate a recycling/waste center
  companyRole        CompanyRole? // role within their company; null for solo accounts
  status             UserStatus   @default(ACTIVE) // buyers are auto-activated
  emailVerified      Boolean      @default(false)
  phoneVerified      Boolean      @default(false)
  pushToken          String? // Expo push token for native notifications
  resetToken         String? // password-reset token (hashed SHA-256)
  resetTokenExpiry   DateTime? // token expiry (1h window)
  refreshToken       String? // hashed refresh token (30-day sliding window)
  refreshTokenExpiry DateTime? // refresh token expiry
  emailVerifyToken   String?   // email verification token (hashed SHA-256)
  emailVerifyExpiry  DateTime? // verification token expiry (24h window)
  failedLoginAttempts Int       @default(0) // consecutive failed login attempts
  lockedUntil        DateTime? // account locked until this timestamp
  termsAcceptedAt    DateTime? // timestamp when user accepted T&C / Privacy Policy
  tokenVersion       Int       @default(0) // incremented on capability/role changes; JWT claims become stale if lower

  // Notification preferences
  notifPush         Boolean @default(true)
  notifOrderUpdates Boolean @default(true)
  notifJobAlerts    Boolean @default(true)
  notifMarketing    Boolean @default(false)

  // Company sub-user permissions (ignored for OWNER — they always have full access)
  permCreateContracts Boolean @default(false) // create & manage framework contracts
  permReleaseCallOffs Boolean @default(false) // release call-offs against contract positions
  permManageOrders    Boolean @default(false) // place, approve, cancel spot orders
  permViewFinancials  Boolean @default(false) // view invoices, prices, turnover
  permManageTeam      Boolean @default(false) // invite / remove / edit team members

  // Relations
  company   Company? @relation(fields: [companyId], references: [id])
  companyId String?

  // User-specific profiles
  driverProfile DriverProfile?
  buyerProfile  BuyerProfile?

  // Activity
  ordersCreated               Order[]
  driverJobs                  TransportJob[]          @relation("DriverJobs")
  requestedTransportJobs      TransportJob[]          @relation("RequestedJobs")
  notifications               Notification[]
  vehicles                    Vehicle[]
  quoteRequests               QuoteRequest[]
  reviews                     Review[]
  sentMessages                ChatMessage[]
  chatLastReads               ChatLastRead[]
  frameworkContracts          FrameworkContract[]
  projects                    Project[]
  reportedTransportExceptions TransportJobException[] @relation("ExceptionReporter")
  resolvedTransportExceptions TransportJobException[] @relation("ExceptionResolver")
  savedAddresses              SavedAddress[]
  adminAuditLogs              AdminAuditLog[]
  orderSchedules              OrderSchedule[]
  raisedDisputes              Dispute[]               @relation("UserDisputes")
  supportThread               SupportThread?
  supportMessages             SupportMessage[]
  fieldPasses                 FieldPass[]
  driverRatingsGiven          DriverRating[]          @relation("DriverRatingsGiven")
  driverRatingsReceived       DriverRating[]          @relation("BuyerRatingsReceived")
  driverPayouts               CarrierPayout[]         @relation("DriverPayouts")
  dailyReportsCreated         DailyReport[]           @relation("DprCreatedBy")
  dailyReportsApproved        DailyReport[]           @relation("DprApprovedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

/**
 * Ephemeral OTP record for phone-based authentication.
 * One row per phone number — upserted on each new OTP request.
 * Deleted once a user successfully verifies.
 */
model PhoneOtp {
  id        String   @id @default(cuid())
  phone     String   @unique
  code      String   // SHA-256 hash of the 6-digit code
  expiresAt DateTime
  attempts  Int      @default(0) // failed verify attempts (blocked after 5)
  createdAt DateTime @default(now())

  @@map("phone_otps")
}

model Company {
  id              String      @id @default(cuid())
  name            String
  legalName       String
  registrationNum String?     @unique
  taxId           String?
  companyType     CompanyType
  features        CompanyFeature[] // Enabled SaaS feature modules for this company

  // Contact
  email   String
  phone   String
  website String?

  // Address
  street     String
  city       String
  state      String
  postalCode String
  country    String @default("LV")

  // Business info
  description String?
  logo        String?
  verified    Boolean @default(false)
  rating      Float?

  // Payout & Commission
  ibanNumber            String? // IBAN for Paysera IBAN payouts (supplier / carrier)
  commissionRate        Float   @default(6.0) // Supplier platform fee % (applied to material subtotal)
  carrierCommissionRate Float   @default(8.0) // Carrier platform fee % (applied to deliveryFee)
  payoutEnabled         Boolean @default(false) // true once IBAN is verified

  // Billing settings — used on supplier-issued invoices
  paymentTermsDays Int?    // Default payment period in days (e.g. 14, 30). Falls back to 14 if null.

  // Marketplace billing agent agreement — supplier accepts that B3Hub generates
  // invoices on their behalf (required for Path 1 / disclosed agent model).
  billingAgentAgreedAt DateTime? // null = not yet accepted; non-null = accepted

  // Geo coordinates (set during onboarding — used for delivery-radius filtering in catalog)
  lat Float? // WGS-84 latitude of warehouse / base location
  lng Float? // WGS-84 longitude of warehouse / base location

  // Carrier operational area
  serviceRadiusKm Int? // Max km radius from base city for skip-hire jobs (null = no restriction)

  // Performance stats — refreshed nightly by AnalyticsService.refreshSupplierStats()
  onTimePct      Float? // % of transport jobs delivered on time
  fulfillmentPct Float? // % of orders completed (not cancelled / rejected)

  // Relations
  users            User[]
  materials        Material[]
  containers       Container[]
  vehicles         Vehicle[]
  orders           Order[]
  recyclingCenters RecyclingCenter[]
  carrierJobs      TransportJob[]
  quoteResponses   QuoteResponse[]

  // Carrier comparison engine
  carrierPricing             CarrierPricing[]      @relation("CarrierPricing")
  serviceZones               CarrierServiceZone[]  @relation("CarrierServiceZones")
  availabilityBlocks         CarrierAvailability[] @relation("CarrierAvailability")
  assignedSkipOrders         SkipHireOrder[]       @relation("AssignedSkipCarrier")
  reviews                    Review[]
  frameworkContracts         FrameworkContract[]   @relation("BuyerFrameworkContracts")
  supplierFrameworkContracts FrameworkContract[]   @relation("SupplierFrameworkContracts")
  projects                   Project[]
  apiKeys                    ApiKey[]
  fieldPasses                FieldPass[]
  advanceInvoices            Invoice[]             @relation("BuyerInvoices")
  sellerInvoices             Invoice[]             @relation("SellerInvoices")
  supplierPayouts            SupplierPayout[]      @relation("SupplierPayouts")
  carrierPayouts             CarrierPayout[]       @relation("CarrierPayouts")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("companies")
}

model Material {
  id          String           @id @default(cuid())
  name        String
  description String?
  category    MaterialCategory
  subCategory String?

  // Pricing
  basePrice Float
  unit      MaterialUnit
  currency  String       @default("EUR")

  // Stock & Availability
  inStock          Boolean @default(true)
  stockQty         Float?  // actual quantity in stock (null = unlimited / not tracked)
  minOrder         Float?
  maxOrder         Float?
  deliveryRadiusKm Int?    @default(100) // km radius the supplier delivers

  // Quality
  isRecycled   Boolean  @default(false)
  quality      String? // Quality grade
  certificates String[] // Certification IDs

  // Visibility
  featured Boolean @default(false) // promoted listing — sorted to top in catalog

  // Media
  images         String[]
  specifications Json?

  // Relations
  supplier            Company                      @relation(fields: [supplierId], references: [id])
  supplierId          String
  orderItems          OrderItem[]
  priceTiers          MaterialPriceTier[]
  availabilityBlocks  MaterialAvailabilityBlock[]

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([supplierId])
  @@index([active, category])
  @@index([active, featured])
  @@map("materials")
}

model MaterialAvailabilityBlock {
  id         String   @id @default(cuid())
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  materialId String

  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  note      String?

  createdAt DateTime @default(now())

  @@map("material_availability_blocks")
}

model Container {
  id            String        @id @default(cuid())
  containerType ContainerType
  size          ContainerSize
  volume        Float // in m3
  maxWeight     Float // in tonnes

  // Pricing
  rentalPrice Float // per day
  deliveryFee Float
  pickupFee   Float
  currency    String @default("EUR")

  // Availability
  status   ContainerStatus
  location String? // Current location

  // Relations
  owner           Company          @relation(fields: [ownerId], references: [id])
  ownerId         String
  containerOrders ContainerOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("containers")
}

model Order {
  id          String    @id @default(cuid())
  orderNumber String    @unique
  orderType   OrderType

  // Customer info
  buyer       Company @relation(fields: [buyerId], references: [id])
  buyerId     String
  createdBy   User    @relation(fields: [createdById], references: [id])
  createdById String

  // Delivery details
  deliveryAddress String
  deliveryCity    String
  deliveryState   String
  deliveryPostal  String
  deliveryLat     Float?   // GPS latitude of delivery site — used for route distance & driver matching
  deliveryLng     Float?   // GPS longitude of delivery site
  deliveryDate    DateTime?
  deliveryWindow  String? // e.g., "8:00-12:00"

  // Fulfillment type — DELIVERY (default) or PICKUP at a B3 Field
  fulfillmentType OrderFulfillmentType @default(DELIVERY)
  pickupField     B3Field?    @relation(fields: [pickupFieldId], references: [id])
  pickupFieldId   String?
  pickupSlot      PickupSlot? @relation(fields: [pickupSlotId], references: [id])
  pickupSlotId    String?

  // Pricing
  subtotal    Float
  tax         Float
  deliveryFee Float
  total       Float
  currency    String @default("EUR")

  // Status
  status         OrderStatus
  paymentStatus  PaymentStatus
  paymentMethod  PaymentMethod @default(CARD) // CARD = pay now; INVOICE = NET terms

  // Site contact (foreman / on-site contact the driver can call)
  siteContactName  String?
  siteContactPhone String?

  // Unloading-point photo — buyer can photograph the exact drop zone when placing the order
  sitePhotoUrl  String?

  // Special instructions
  notes         String?
  internalNotes String?

  // BIS (Būvniecības informācijas sistēma) case reference — required for waste disposal orders
  // on construction sites. Collected in the wizard and stored for APUS reporting.
  bisNumber String?

  // Project association (optional — retrospective tagging)
  project   Project? @relation(fields: [projectId], references: [id])
  projectId String?

  // Combo order — optional link to a skip hire order that delivers/collects the material
  linkedSkipOrder   SkipHireOrder? @relation("LinkedMaterialOrder", fields: [linkedSkipOrderId], references: [id])
  linkedSkipOrderId String?        @unique

  // Multi-truck staggered delivery
  truckCount           Int @default(1) // number of separate truck runs
  truckIntervalMinutes Int? // minutes between consecutive trucks; null = all at once

  // Recurring order schedule — if this order spawned from a schedule
  scheduleId String?
  schedule   OrderSchedule? @relation(fields: [scheduleId], references: [id])

  // Public tracking — unauthenticated share link
  trackingToken String? @unique

  // International shipment flag — determines legal document type:
  // false (default) = domestic → Kravas pavadzīme (Latvian cargo bill of lading)
  // true = cross-border → CMR Note (1956 CMR Convention)
  isInternational Boolean @default(false)

  // Timestamps for each status transition — { STATUS: ISO8601 }
  statusTimestamps Json?

  // Relations
  items           OrderItem[]
  containerOrders ContainerOrder[]
  transportJobs   TransportJob[]
  invoices        Invoice[]
  payment         Payment?
  surcharges      OrderSurcharge[]
  dispute         Dispute?
  chatMessages    ChatMessage[]    @relation("OrderChatMessages")
  fieldPasses     FieldPass[]
  supplierPayouts SupplierPayout[] @relation("OrderSupplierPayouts")
  carrierPayouts  CarrierPayout[]  @relation("OrderCarrierPayouts")
  wasteRecords    WasteRecord[]    @relation("DisposalWasteRecord")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([trackingToken])
  @@index([projectId])
  @@index([scheduleId])
  @@index([buyerId])
  @@index([createdById])
  @@index([status])
  @@index([status, createdAt])
  @@map("orders")
}

// ── Guest Order ───────────────────────────────────────────────────────────────
// Unauthenticated B2C order submitted from the public landing page.
// Not linked to any User or Company — just contact info + delivery details.
// Admin/seller is notified and can contact the guest directly, or the guest
// can later register and have the order converted to a real Order.
model GuestOrder {
  id          String           @id @default(cuid())
  orderNumber String           @unique
  token       String           @unique // public tracking token — /order/[token]

  // Category discriminator (MATERIAL | SKIP_HIRE | TRANSPORT | DISPOSAL)
  category String @default("MATERIAL")

  // ── MATERIAL specific (nullable for other categories) ──
  materialCategory String?  // mirrors MaterialCategory enum values
  materialName     String?
  quantity         Float?
  unit             String?  // TONNE | M3 | KG | PIECE

  // ── SKIP_HIRE specific ──
  skipSize          String?  // SkipSize enum value
  skipWasteCategory String?  // SkipWasteCategory enum value
  hireDays          Int?
  collectionDate    DateTime?

  // ── TRANSPORT specific ──
  pickupAddress    String?
  pickupCity       String?
  pickupLat        Float?
  pickupLng        Float?
  vehicleType      String?   // TransportVehicleType enum value
  cargoDescription String?
  estimatedWeight  Float?

  // ── DISPOSAL specific ──
  wasteTypes     String?  // JSON string array e.g. '["CONCRETE","SOIL"]'
  disposalVolume Float?
  truckType      String?  // DisposalTruckType enum value

  // Where (shared — delivery/placement/dropoff address)
  deliveryAddress String
  deliveryCity    String
  deliveryPostal  String?
  deliveryLat     Float?
  deliveryLng     Float?

  // When
  deliveryDate   DateTime?
  deliveryWindow String?   // e.g. "08:00-12:00"

  // Who (guest contact — no account required)
  contactName  String
  contactPhone String
  contactEmail String?
  notes        String?

  // Lifecycle
  status GuestOrderStatus @default(PENDING)

  // Optional: if converted, link to the real order
  convertedOrderId String? @unique

  // Paysera payment — populated when guest initiates checkout
  payseraOrderId    String? // Paysera order UUID
  payseraPaymentUrl String? // Checkout redirect URL sent to guest
  paymentStatus     String? // 'PENDING' | 'PAID' | 'FAILED'

  // Price quoted to guest (set by admin before sending payment link)
  quotedAmount   Float?
  quotedCurrency String @default("EUR")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([token])
  @@index([status])
  @@index([contactPhone])
  @@map("guest_orders")
}

enum GuestOrderStatus {
  PENDING    // received, awaiting admin/seller action
  CONTACTED  // admin or seller has reached out to the guest
  CONVERTED  // guest registered and order moved to Order model
  CANCELLED
}

model OrderItem {
  id String @id @default(cuid())

  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId    String
  material   Material @relation(fields: [materialId], references: [id])
  materialId String

  quantity  Float
  unit      MaterialUnit
  unitPrice Float
  total     Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("order_items")
}

model ContainerOrder {
  id String @id @default(cuid())

  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     String
  container   Container @relation(fields: [containerId], references: [id])
  containerId String

  // Rental period
  startDate     DateTime
  endDate       DateTime?
  actualEndDate DateTime?

  // Purpose
  purpose         WastePurpose
  wasteType       WasteType?
  estimatedWeight Float?
  actualWeight    Float?

  // Pricing
  rentalDays  Int
  dailyRate   Float
  deliveryFee Float
  pickupFee   Float
  disposalFee Float?
  total       Float

  // Status
  status ContainerOrderStatus

  // Delivery & Pickup
  deliveryJob   TransportJob? @relation("ContainerDelivery", fields: [deliveryJobId], references: [id])
  deliveryJobId String?
  pickupJob     TransportJob? @relation("ContainerPickup", fields: [pickupJobId], references: [id])
  pickupJobId   String?
  wasteRecords  WasteRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("container_orders")
}

model TransportJob {
  id        String           @id @default(cuid())
  jobNumber String           @unique
  jobType   TransportJobType

  // Job details
  order   Order?  @relation(fields: [orderId], references: [id])
  orderId String?

  // Pickup
  pickupAddress String
  pickupCity    String
  pickupState   String
  pickupPostal  String
  pickupDate    DateTime
  pickupWindow  String?

  // Delivery
  deliveryAddress String
  deliveryCity    String
  deliveryState   String
  deliveryPostal  String
  deliveryDate    DateTime
  deliveryWindow  String?

  // Cargo
  cargoType           String
  cargoWeight         Float? // estimated weight in tonnes
  cargoVolume         Float?
  actualWeightKg      Float? // actual weigh-bridge reading at pickup
  pickupPhotoUrl      String? // weighing slip photo taken by driver at pickup
  specialRequirements String?

  // Required vehicle
  requiredVehicleType String? // human-readable e.g. "Sattelkipper"
  requiredVehicleEnum VehicleType?

  // Staggered delivery — which run this job represents (1-based)
  truckIndex Int?

  // Geo coords for radius filtering
  pickupLat   Float?
  pickupLng   Float?
  deliveryLat Float?
  deliveryLng Float?
  distanceKm  Float?

  // Pricing
  rate              Float
  pricePerTonne     Float?
  buyerOfferedRate  Float?   // buyer's suggested budget; shown to drivers
  currency          String @default("EUR")

  // Assignment
  carrier   Company? @relation(fields: [carrierId], references: [id])
  carrierId String?
  driver    User?    @relation("DriverJobs", fields: [driverId], references: [id])
  driverId  String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])
  vehicleId String?

  // Framework contract call-off
  frameworkContract   FrameworkContract? @relation(fields: [frameworkContractId], references: [id])
  frameworkContractId String?
  frameworkPosition   FrameworkPosition? @relation("PositionCallOffs", fields: [frameworkPositionId], references: [id])
  frameworkPositionId String?

  // The buyer/user who originally requested this disposal or freight job
  requester     User?   @relation("RequestedJobs", fields: [requestedById], references: [id])
  requestedById String? @map("requested_by_id")

  // Recycling center destination (set for WASTE_COLLECTION jobs)
  recyclingCenter   RecyclingCenter? @relation(fields: [recyclingCenterId], references: [id])
  recyclingCenterId String?

  // Status
  status TransportJobStatus

  // SLA / escalation tracking
  acceptedAt         DateTime?
  statusUpdatedAt    DateTime?
  slaEscalatedAt     DateTime?
  slaEscalationStage String?

  // Per-status timestamps — JSON map of { STATUS: ISO-8601 string }
  // e.g. { "ACCEPTED": "2026-04-19T10:00:00Z", "EN_ROUTE_PICKUP": "..." }
  statusTimestamps Json?

  // Tracking
  currentLocation  Json?
  estimatedArrival DateTime?

  // Proof of delivery
  deliveryProof DeliveryProof?

  // Auto-dispatch offer
  offeredToDriverId String?   // current driver being offered this job
  offerExpiresAt    DateTime? // offer expires at this time (45 seconds from dispatch)
  declinedDriverIds String[]  @default([]) // driver IDs who declined or timed out

  // Project association (disposal and standalone freight jobs)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId String?

  // Relations
  containerDeliveries ContainerOrder[]        @relation("ContainerDelivery")
  containerPickups    ContainerOrder[]        @relation("ContainerPickup")
  chatMessages        ChatMessage[]
  exceptions          TransportJobException[]
  invoices            Invoice[]
  surcharges          OrderSurcharge[]        @relation("JobSurcharges")
  driverRating        DriverRating?
  carrierPayout       CarrierPayout?          @relation("JobCarrierPayout")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([driverId])
  @@index([carrierId])
  @@index([orderId])
  @@index([projectId])
  @@index([status])
  @@index([status, pickupDate])
  @@map("transport_jobs")
}

model TransportJobException {
  id String @id @default(cuid())

  transportJob   TransportJob @relation(fields: [transportJobId], references: [id], onDelete: Cascade)
  transportJobId String

  type      TransportExceptionType
  status    TransportExceptionStatus @default(OPEN)
  notes     String
  photoUrls String[]

  reportedBy   User   @relation("ExceptionReporter", fields: [reportedById], references: [id])
  reportedById String

  resolvedBy   User?   @relation("ExceptionResolver", fields: [resolvedById], references: [id])
  resolvedById String?
  resolution   String?

  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([transportJobId, status])
  @@map("transport_job_exceptions")
}

model DeliveryProof {
  id             String       @id @default(cuid())
  transportJob   TransportJob @relation(fields: [transportJobId], references: [id])
  transportJobId String       @unique

  // Signatures
  recipientName      String
  recipientSignature String // Base64 or URL
  driverSignature    String // Base64 or URL

  // Photos
  photos String[] // URLs

  // Timestamps
  deliveredAt DateTime

  // Notes
  notes String?

  // GPS coordinates captured at the moment of proof submission
  proofLat Float?
  proofLng Float?

  // Structured checklist fields
  loadCondition  String?  // 'FULL' | 'PARTIAL' | 'DAMAGED'
  isPartialLoad  Boolean  @default(false)
  hasDamage      Boolean  @default(false)
  damageNote     String?
  gradeConfirmed Boolean  @default(false)

  createdAt DateTime @default(now())

  @@map("delivery_proofs")
}

model Vehicle {
  id           String  @id @default(cuid())
  make         String
  model        String
  year         Int
  licensePlate String  @unique
  vin          String?
  imageUrl     String?

  // Type & Capacity
  vehicleType    VehicleType
  capacity       Float // load weight in tonnes
  maxGrossWeight Float? // total permitted weight in tonnes
  volumeCapacity Float? // in m3
  driveType      String? // '4WD', 'AWD', '2WD', etc.

  // Individual owner (solo CARRIER without a company)
  owner   User?   @relation(fields: [ownerId], references: [id])
  ownerId String?

  // Company owner
  company   Company? @relation(fields: [companyId], references: [id])
  companyId String?

  // Status
  status          VehicleStatus @default(ACTIVE)
  currentLocation Json?

  // Insurance & Compliance
  insuranceExpiry  DateTime?
  inspectionExpiry DateTime?

  // Relations
  transportJobs TransportJob[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("vehicles")
}

model RecyclingCenter {
  id   String @id @default(cuid())
  name String

  // Location
  address     String
  city        String
  state       String
  postalCode  String
  coordinates Json? // {lat, lng}

  // Owner
  company   Company @relation(fields: [companyId], references: [id])
  companyId String

  // Capabilities
  acceptedWasteTypes WasteType[]
  capacity           Float // tonnes per day
  certifications     String[]

  // Operating hours
  operatingHours Json // {monday: {open, close}, ...}

  // APUS / licensing
  licensed           Boolean @default(false) // true = VVD-licensed recycling facility (Gulbene)
  apusRegistrationId String? // VVD-issued APUS facility registration number

  // Status
  active Boolean @default(true)

  // Relations
  wasteRecords  WasteRecord[]
  incomingJobs  TransportJob[] // WASTE_COLLECTION jobs destined for this center
  b3Field       B3Field? // reverse of B3Field.recyclingCenter

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("recycling_centers")
}

model WasteRecord {
  id String @id @default(cuid())

  // Source
  containerOrder   ContainerOrder? @relation(fields: [containerOrderId], references: [id])
  containerOrderId String?

  // Recycling center
  recyclingCenter   RecyclingCenter @relation(fields: [recyclingCenterId], references: [id])
  recyclingCenterId String

  // Waste details
  wasteType WasteType
  weight    Float
  volume    Float?

  // Processing
  processedDate    DateTime?
  recyclableWeight Float?
  recyclingRate    Float? // percentage

  // Output
  producedMaterialId String? // If converted to recycled material

  // Compliance
  certificateUrl String?

  // APUS (Atkritumu plūsmu uzskaites sistēma) — VVD mandatory reporting
  apusStatus       ApusStatus @default(PENDING)
  apusSubmissionId String?    // reference ID returned by APUS after submission
  apusSubmittedAt  DateTime?
  apusNote         String?    // rejection reason or manual staff note
  bisNumber        String?    // BIS case reference from source Order (for construction waste)

  // Source Order link (disposal orders that created this record)
  order   Order?  @relation("DisposalWasteRecord", fields: [orderId], references: [id])
  orderId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("waste_records")
}

model DriverProfile {
  id String @id @default(cuid())

  user   User   @relation(fields: [userId], references: [id])
  userId String @unique

  // License info
  licenseNumber String   @unique
  licenseType   String[] // ["B", "C", "CE"]
  licenseExpiry DateTime

  // Certifications
  certifications String[]

  // Performance
  rating        Float?
  completedJobs Int    @default(0)
  noShowCount   Int    @default(0)  // incremented on every driver-initiated cancellation

  // Status
  available       Boolean @default(true) // legacy; now derived from isOnline + schedule
  isOnline        Boolean @default(false) // driver tapped "Go Online"
  autoSchedule    Boolean @default(false) // auto toggle based on weeklySchedule
  maxJobsPerDay   Int? // cap on daily job accepts; null = unlimited
  currentLocation Json?

  // Payout info for individual owner-operators (no company)
  ibanNumber    String? // IBAN for Paysera IBAN payouts
  payoutEnabled Boolean @default(false) // true once IBAN is set and verified

  // Schedule relations
  weeklySchedule DriverSchedule[]
  dateBlocks     DriverDateBlock[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("driver_profiles")
}

model BuyerProfile {
  id String @id @default(cuid())

  user   User   @relation(fields: [userId], references: [id])
  userId String @unique

  // Preferences
  preferredSuppliers String[]
  preferredCarriers  String[]

  // Credit
  creditLimit  Float?
  creditUsed   Float   @default(0)
  paymentTerms String? // e.g., "NET30"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("buyer_profiles")
}

model Notification {
  id String @id @default(cuid())

  user   User   @relation(fields: [userId], references: [id])
  userId String

  type    NotificationType
  title   String
  message String
  data    Json? // Additional data

  read   Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, read])
  @@map("notifications")
}

model Invoice {
  id            String @id @default(cuid())
  invoiceNumber String @unique

  order   Order?  @relation(fields: [orderId], references: [id])
  orderId String?

  // Framework contract call-off billing: invoice linked to a transport job (no Order record)
  transportJob   TransportJob? @relation(fields: [transportJobId], references: [id])
  transportJobId String?

  // B3 Fields — advance payment invoice linked to a field contract
  advanceForContract   FrameworkContract? @relation("AdvanceInvoices", fields: [advanceForContractId], references: [id])
  advanceForContractId String?

  // Buyer — who this invoice belongs to (set for advance invoices; derived from order for order invoices)
  buyerCompany   Company? @relation("BuyerInvoices", fields: [buyerCompanyId], references: [id])
  buyerCompanyId String?

  // Marketplace / Path 1: which company is the legal seller on this invoice.
  // Null = B3Hub is the issuer (legacy / commission invoices).
  // Non-null = supplier-issued invoice generated by B3Hub acting as billing agent.
  sellerCompany   Company? @relation("SellerInvoices", fields: [sellerCompanyId], references: [id])
  sellerCompanyId String?

  // Commission invoice — B3Hub's platform fee invoice issued TO the supplier.
  // When true: buyerCompanyId = supplier company, sellerCompanyId = null (B3Hub is issuer).
  isCommissionInvoice    Boolean  @default(false)
  commissionForInvoiceId String?  // links to the supplier-issued invoice this fee is based on

  // Amounts
  subtotal Float
  tax      Float
  total    Float
  currency String @default("EUR")

  // Payment
  dueDate       DateTime
  paidDate      DateTime?
  paymentStatus PaymentStatus

  // Documents
  pdfUrl String?

  // VAT compliance fields — required by LV Cabinet Regulation No. 585 (VAT Directive)
  supplierVatNumber   String? // Piegādātāja PVN reģistrācijas numurs
  buyerVatNumber      String? // Pircēja PVN reģistrācijas numurs
  taxPeriod           String? // Nodokļa periods, e.g. "Aprīlis 2026"
  supplierBankAccount String? // Piegādātāja bankas konts un BIC

  // Credit notes — cancels or reduces an already-issued invoice (kredītrēķins)
  isCreditNote    Boolean  @default(false)
  creditNoteForId String?
  creditNoteFor   Invoice? @relation("InvoiceCreditNotes", fields: [creditNoteForId], references: [id], onDelete: SetNull)
  creditNotes     Invoice[] @relation("InvoiceCreditNotes")
  notes           String?  // Free-text reason, e.g. credit note explanation

  // Paysera payment link — populated for INVOICE-method orders so buyer can pay online
  payseraPaymentLinkId  String?
  payseraPaymentLinkUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([creditNoteForId])
  @@index([sellerCompanyId])
  @@index([isCommissionInvoice])
  @@map("invoices")
}

// ── Digital Documents ─────────────────────────────────────────

enum DocumentType {
  INVOICE // Invoice / bill
  WEIGHING_SLIP // Weight certificate when materials are loaded / delivered
  DELIVERY_PROOF // Signed proof of delivery with photos
  WASTE_CERTIFICATE // Recycling / waste processing certificate
  DELIVERY_NOTE // Kravas pavadzīme (domestic) or CMR Note (cross-border) — pre-generated at job accept
  WASTE_TRANSPORT_NOTE // Atkritumu pārvadājuma pavadzīme — required pre-transport waste document (LV law)
  CONTRACT // Agreement / contract between parties
  OTHER
}

enum DocumentStatus {
  DRAFT
  ISSUED
  SIGNED
  ARCHIVED
}

enum DocumentEntityType {
  ORDER
  INVOICE
  TRANSPORT_JOB
  WASTE_RECORD
  SKIP_HIRE_ORDER
  FRAMEWORK_CONTRACT
  FRAMEWORK_POSITION
  COMPANY
  PROJECT
}

enum DocumentLinkRole {
  PRIMARY
  RELATED
  SUPPORTING
}

model Document {
  id     String         @id @default(cuid())
  title  String
  type   DocumentType
  status DocumentStatus @default(ISSUED)

  // Storage
  fileUrl  String? // Supabase / S3 signed URL
  mimeType String? // application/pdf, image/jpeg, …
  fileSize Int? // bytes

  // Linked entities (all optional – attach to whatever is relevant)
  orderId        String?
  invoiceId      String?
  transportJobId String?
  wasteRecordId  String?
  skipHireId     String?

  // Ownership
  ownerId  String // User who can see this document
  issuedBy String? // Company / system that issued it

  // Metadata
  isGenerated Boolean   @default(false) // true = auto-generated by backend
  notes       String?
  expiresAt   DateTime?

  // Contextual links (one document can belong to many entities)
  links DocumentLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("documents")
}

model DocumentLink {
  id String @id @default(cuid())

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId String

  entityType DocumentEntityType
  entityId   String
  role       DocumentLinkRole   @default(RELATED)

  createdAt DateTime @default(now())

  @@unique([documentId, entityType, entityId, role])
  @@index([entityType, entityId])
  @@map("document_links")
}

// ── CMS-managed skip/container size catalogue ──────────────────────────────
model SkipSizeDefinition {
  id          String      @id @default(cuid())
  code        String      @unique // internal key used in orders, e.g. "MIDI", "BIG_BAG_1M3"
  label       String              // display name, e.g. "Midi Skip (4 m³)"
  labelLv     String?             // Latvian label override
  volumeM3    Float               // volume in cubic metres
  category    SkipCategory        // SKIP | BIG_BAG | CONTAINER
  description String?
  descriptionLv String?
  heightPct   Float  @default(0.5) // 0–1 visual proportion used in mobile UI
  basePrice   Float?               // fallback/suggested price if carrier hasn't set one
  currency    String @default("EUR")
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, category])
  @@map("skip_size_definitions")
}

// ── Public skip-hire orders (4-step wizard, no auth required) ──
model SkipHireOrder {
  id          String @id @default(cuid())
  orderNumber String @unique

  // Step 1 — Location
  location String // Postal code or city entered by user

  // Step 2 — Waste type
  wasteCategory SkipWasteCategory

  // Step 3 — Skip size (references SkipSizeDefinition.code)
  skipSize String

  // Step 4 — Delivery date
  deliveryDate   DateTime
  deliveryWindow String? // 'AM' (8–13) | 'PM' (13–18) | 'ANY'
  hireDays       Int?    // hire period in days (e.g. 7, 14, 28)

  // Pricing (stored at time of order)
  price    Float
  currency String @default("EUR")

  // Payment tracking
  paymentMethod     PaymentMethod @default(CARD)  // CARD = Paysera redirect; INVOICE = bank transfer
  payseraOrderId    String?       // Paysera order UUID
  payseraPaymentUrl String?       // Checkout redirect URL
  paymentStatus     PaymentStatus @default(PENDING)

  // Status lifecycle
  status SkipHireStatus @default(PENDING)

  // Optional contact info (guest or registered user)
  contactName  String?
  contactEmail String?
  contactPhone String?

  // If placed by a registered user
  userId String?

  // Internal notes
  notes String?

  // BIS (Būvniecības informācijas sistēma) case reference — for construction-site skips
  bisNumber String?

  // Optional unloading point photo (URL or data URI) captured during booking
  unloadingPointPhotoUrl String?

  // Carrier assigned during quote selection
  carrier   Company? @relation("AssignedSkipCarrier", fields: [carrierId], references: [id])
  carrierId String?

  // Geocoded coordinates (resolved at booking time on the client)
  lat Float?
  lng Float?

  // Reverse relation — the material order that this skip is linked to (if any)
  linkedMaterialOrder Order? @relation("LinkedMaterialOrder")

  // Per-status timestamps: { PENDING: "2024-01-01T00:00:00.000Z", CONFIRMED: "...", ... }
  statusTimestamps Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("skip_hire_orders")
}

// ── Carrier comparison engine ─────────────────────────────────────────────────

model CarrierPricing {
  id        String  @id @default(cuid())
  carrier   Company @relation("CarrierPricing", fields: [carrierId], references: [id], onDelete: Cascade)
  carrierId String

  skipSize String // references SkipSizeDefinition.code
  price    Float
  currency String   @default("EUR")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([carrierId, skipSize])
  @@map("carrier_pricing")
}

model CarrierServiceZone {
  id        String  @id @default(cuid())
  carrier   Company @relation("CarrierServiceZones", fields: [carrierId], references: [id], onDelete: Cascade)
  carrierId String

  city      String // e.g. "Rīga", "Jūrmala"
  postcode  String? // optional tighter targeting
  surcharge Float   @default(0)

  createdAt DateTime @default(now())

  @@map("carrier_service_zones")
}

model CarrierAvailability {
  id        String  @id @default(cuid())
  carrier   Company @relation("CarrierAvailability", fields: [carrierId], references: [id], onDelete: Cascade)
  carrierId String

  blockedDate DateTime @db.Date
  reason      String?

  createdAt DateTime @default(now())

  @@unique([carrierId, blockedDate])
  @@map("carrier_availability")
}

// ── Provider Applications (supply/transport onboarding) ─────────────────────
model ProviderApplication {
  id String @id @default(cuid())

  // Applicant identity
  email     String
  firstName String
  lastName  String
  phone     String

  // Company details
  companyName String
  regNumber   String?
  taxId       String?
  website     String?

  // What they want to do
  appliesForSell      Boolean @default(false) // wants canSell
  appliesForTransport Boolean @default(false) // wants canTransport

  // Supporting info
  description String? // Free-text: describe your business

  // Linked to an existing user (optional — may apply before registering)
  userId String?

  // Review
  status     ApplicationStatus @default(PENDING)
  reviewedBy String? // Admin userId who reviewed
  reviewNote String? // Admin note

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("provider_applications")
}

// ── Driver scheduling ─────────────────────────────────────────────────────────

// Recurring weekly work hours (one row per day of week the driver works)
model DriverSchedule {
  id String @id @default(cuid())

  driverProfile   DriverProfile @relation(fields: [driverProfileId], references: [id], onDelete: Cascade)
  driverProfileId String

  dayOfWeek Int // 0 = Sunday … 6 = Saturday
  enabled   Boolean @default(true)
  startTime String // "07:00" (local time, HH:mm)
  endTime   String // "18:00"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([driverProfileId, dayOfWeek])
  @@map("driver_schedules")
}

// Specific dates the driver cannot work (vacation, sick day, personal)
model DriverDateBlock {
  id String @id @default(cuid())

  driverProfile   DriverProfile @relation(fields: [driverProfileId], references: [id], onDelete: Cascade)
  driverProfileId String

  blockedDate DateTime
  reason      String?

  createdAt DateTime @default(now())

  @@unique([driverProfileId, blockedDate])
  @@map("driver_date_blocks")
}

// ── Material Marketplace: Quote Requests ─────────────────────────────────────

// A buyer's open request for pricing when no instant offer is available
model QuoteRequest {
  id            String @id @default(cuid())
  requestNumber String @unique

  buyer   User   @relation(fields: [buyerId], references: [id])
  buyerId String

  // What they want
  materialCategory MaterialCategory
  materialName     String
  quantity         Float
  unit             MaterialUnit

  // Delivery
  deliveryAddress String
  deliveryCity    String
  deliveryLat     Float?
  deliveryLng     Float?

  // Status & notes
  status QuoteRequestStatus @default(PENDING)
  notes  String?

  responses QuoteResponse[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("quote_requests")
}

// A supplier's response to a QuoteRequest
model QuoteResponse {
  id String @id @default(cuid())

  request   QuoteRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  requestId String

  supplier   Company @relation(fields: [supplierId], references: [id])
  supplierId String

  pricePerUnit Float
  totalPrice   Float
  unit         MaterialUnit
  etaDays      Int
  notes        String?
  validUntil   DateTime?

  status QuoteResponseStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("quote_responses")
}

// ── Reviews / Ratings ─────────────────────────────────────────────────────────

// A buyer review submitted after a completed order
model Review {
  id      String  @id @default(cuid())
  rating  Int // 1–5 stars
  comment String?

  reviewer   User   @relation(fields: [reviewerId], references: [id])
  reviewerId String

  company   Company @relation(fields: [companyId], references: [id])
  companyId String

  // Exactly one of these is set per review
  orderId          String? @unique // material order
  skipOrderId      String? @unique // skip-hire order
  transportJobId   String? @unique // driver rating (buyer rates driver post-delivery)

  // Set for driver ratings — the individual driver being rated
  driverId String?

  createdAt DateTime @default(now())

  @@map("reviews")
}

// ── Driver → Buyer reverse rating ─────────────────────────────────────────────
// Driver rates the buyer's site/instructions after a delivered transport job.

model DriverRating {
  id      String  @id @default(cuid())
  rating  Int     // 1–5 stars
  comment String?

  driver   User   @relation("DriverRatingsGiven", fields: [driverId], references: [id])
  driverId String

  buyer   User   @relation("BuyerRatingsReceived", fields: [buyerId], references: [id])
  buyerId String

  transportJob   TransportJob @relation(fields: [transportJobId], references: [id])
  transportJobId String       @unique

  createdAt DateTime @default(now())

  @@map("driver_ratings")
}

// ── Per-job Chat ──────────────────────────────────────────────────────────────

model ChatMessage {
  id String @id @default(cuid())

  transportJob   TransportJob? @relation(fields: [transportJobId], references: [id], onDelete: Cascade)
  transportJobId String?

  order   Order? @relation("OrderChatMessages", fields: [orderId], references: [id], onDelete: Cascade)
  orderId String?

  sender   User   @relation(fields: [senderId], references: [id])
  senderId String

  senderName String  // denormalized for quick display
  body       String
  imageUrl   String? // optional photo attachment (Supabase Storage URL)

  createdAt DateTime @default(now())

  @@index([transportJobId, createdAt])
  @@index([orderId, createdAt])
  @@map("chat_messages")
}

/** Tracks the last time a user read a specific chat room (job or order). */
model ChatLastRead {
  id             String    @id @default(cuid())

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String

  transportJobId String?
  orderId        String?

  lastReadAt     DateTime  @default(now())

  @@unique([userId, transportJobId])
  @@unique([userId, orderId])
  @@index([userId])
  @@map("chat_last_reads")
}

// ── Framework Contracts (blanket agreements / call-off orders) ────────────────

model FrameworkContract {
  id             String @id @default(cuid())
  contractNumber String @unique
  title          String

  buyer       Company @relation("BuyerFrameworkContracts", fields: [buyerId], references: [id])
  buyerId     String
  createdBy   User    @relation(fields: [createdById], references: [id])
  createdById String

  supplier   Company? @relation("SupplierFrameworkContracts", fields: [supplierId], references: [id])
  supplierId String?

  status    FrameworkContractStatus @default(DRAFT)
  startDate DateTime
  endDate   DateTime?
  notes     String?

  // B3 Fields — site access contract
  isFieldContract Boolean @default(false)  // true = waste disposal / site entry agreement
  prepaidBalance  Float   @default(0)      // total advance payments received (EUR)
  prepaidUsed     Float   @default(0)      // consumed by issued field passes (EUR)

  // Optional link to a Project (P&L roll-up)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId String?

  positions   FrameworkPosition[]
  callOffJobs TransportJob[]
  fieldPasses FieldPass[]
  advanceInvoices Invoice[]         @relation("AdvanceInvoices")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("framework_contracts")
}

model FrameworkPosition {
  id String @id @default(cuid())

  contract   FrameworkContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  contractId String

  positionType FrameworkPositionType
  description  String
  agreedQty    Float // total agreed quantity
  unit         String                @default("t") // t, m3, loads
  unitPrice    Float?

  pickupAddress   String?
  pickupCity      String?
  deliveryAddress String?
  deliveryCity    String?

  callOffs TransportJob[] @relation("PositionCallOffs")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("framework_positions")
}

// ── Construction Project Management ──────────────────────────────────────────

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  clientName  String?       // End client this project is for
  siteAddress String?       // Legacy single-site address (kept for backwards compat)

  // Financials
  contractValue Float        // Revenue: what their client pays them
  budgetAmount  Float?       // Optional: material spend cap

  status    ProjectStatus @default(PLANNING)
  startDate DateTime?
  endDate   DateTime?

  // Ownership
  company     Company @relation(fields: [companyId], references: [id])
  companyId   String
  createdBy   User    @relation(fields: [createdById], references: [id])
  createdById String

  // Tagged orders (costs)
  orders Order[]

  // Tagged transport & disposal jobs
  transportJobs TransportJob[]

  // Linked framework contracts
  frameworkContracts FrameworkContract[]

  // Delivery / loading sites
  sites ProjectSite[]

  // Daily production reports
  dailyReports DailyReport[]

  // DPR templates pinned to this project
  dprTemplates DprTemplate[]

  // Per-cost-code budget allocations
  budgetLines ProjectBudgetLine[]

  // Subcontractor engagements on this project
  subcontractorEngagements SubcontractorEngagement[]

  // Client invoices issued for this project
  clientInvoices ConstructionClientInvoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@map("projects")
}

enum ProjectSiteType {
  LOADING
  UNLOADING
  BOTH
}

model ProjectSite {
  id        String          @id @default(cuid())
  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  label     String          // e.g. "Iekraušanas punkts", "Objekts A"
  address   String
  lat       Float?
  lng       Float?
  type      ProjectSiteType @default(BOTH)
  isDefault Boolean         @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@map("project_sites")
}

// ── Surcharge line items ─────────────────────────────────────────────────────
// Billable levies added to an order after initial placement:
// fuel, waiting time, weekend rates, overweight, toll pass-throughs.
// Each surcharge is a separate signed line item on the order.

model OrderSurcharge {
  id    String @id @default(cuid())

  // Linked to an Order (regular material/freight job) OR a TransportJob (call-off job — no parent order)
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String?

  transportJob   TransportJob? @relation("JobSurcharges", fields: [transportJobId], references: [id], onDelete: Cascade)
  transportJobId String?

  type     SurchargeType
  label    String         // Human-readable description shown on invoice
  amount   Float          // EUR; positive = charge to buyer
  currency String         @default("EUR")
  billable Boolean        @default(true) // false = internal cost record only

  // Admin approval — PENDING until reviewed; APPROVED charges proceed to billing; REJECTED are voided
  approvalStatus  String   @default("APPROVED") // 'PENDING' | 'APPROVED' | 'REJECTED'
  approvedByAdminId String?
  approvedAt        DateTime?
  rejectionNote     String?

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([transportJobId])
  @@index([approvalStatus])
  @@map("order_surcharges")
}

model SavedAddress {
  id    String @id @default(cuid())
  label String          // e.g. "Mājas", "Objekts 14A", "Noliktava"
  address  String        // Full formatted address
  city     String
  lat      Float?
  lng      Float?
  isDefault Boolean     @default(false)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("saved_addresses")
}

// ── Admin audit log ──────────────────────────────────────────────────────────
// Immutable record of every mutating admin action for financial compliance
// and dispute resolution. Never deleted. Retained for minimum 2 years.

model AdminAuditLog {
  id String @id @default(cuid())

  adminId    String // who performed the action
  admin      User   @relation(fields: [adminId], references: [id])

  action     String // e.g. "UPDATE_USER", "APPROVE_APPLICATION", "FORCE_ASSIGN_JOB"
  entityType String // e.g. "User", "Order", "TransportJob", "Company"
  entityId   String // primary key of the affected entity

  before     Json?  // snapshot of relevant fields before mutation
  after      Json?  // snapshot of relevant fields after mutation
  note       String? // optional free-text reason supplied by the admin

  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("admin_audit_logs")
}

// ── Volume price tiers ───────────────────────────────────────────────────────────────────────
// Quantity-break pricing: supplier sets tiers, e.g. ≥0 t = €12, ≥10 t = €10, ≥50 t = €8.
// When an order is placed, the highest matching tier is applied as unitPrice.

model MaterialPriceTier {
  id         String   @id @default(cuid())
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  materialId String

  minQty    Float  // minimum quantity (inclusive) to qualify for this tier
  unitPrice Float  // price per unit at this tier

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([materialId])
  @@map("material_price_tiers")
}

// ── Order schedule (recurring orders) ───────────────────────────────────────────────────
// Stores a template for creating a new Order automatically each period.
// The cron checks nextRunAt daily and clones the template order.

model OrderSchedule {
  id          String  @id @default(cuid())
  createdBy   User    @relation(fields: [createdById], references: [id])
  createdById String

  // The order fields to reproduce each cycle
  orderType       String   // OrderType enum value stored as string
  deliveryAddress String
  deliveryCity    String
  deliveryState   String
  deliveryPostal  String
  deliveryWindow  String?  // e.g. "AM" | "PM" | "ANY"
  deliveryFee     Float    @default(0)
  notes           String?
  siteContactName  String?
  siteContactPhone String?
  projectId        String?
  itemsSnapshot   Json     // Array of {materialId, quantity, unit}

  // Recurrence
  deliveryLat   Float?
  deliveryLng   Float?

  intervalDays  Int      // 1 = daily, 7 = weekly, 14 = fortnightly, 30 = monthly
  nextRunAt     DateTime // next time the cron will fire a new order
  endsAt        DateTime? // optional end date; null = indefinite
  enabled       Boolean  @default(true)

  // Generated orders
  orders        Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([nextRunAt])
  @@index([createdById])
  @@map("order_schedules")
}

// ── Dispute / Claims ─────────────────────────────────────────────────────────

enum DisputeReason {
  SHORT_DELIVERY    // Less material delivered than ordered
  WRONG_MATERIAL    // Wrong material type or grade
  DAMAGE            // Property or site damage
  LATE_DELIVERY     // Delivery significantly later than agreed
  NO_DELIVERY       // Delivery never arrived
  QUALITY_ISSUE     // Material quality did not meet spec
  OTHER
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

model Dispute {
  id          String        @id @default(cuid())
  reason      DisputeReason
  description String
  status      DisputeStatus @default(OPEN)
  resolution  String?
  resolvedAt  DateTime?

  order      Order @relation(fields: [orderId], references: [id])
  orderId    String @unique // one active dispute per order

  raisedBy   User   @relation("UserDisputes", fields: [raisedById], references: [id])
  raisedById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([raisedById])
  @@map("disputes")
}

// ── Support Chat ─────────────────────────────────────────────────────────────

model SupportThread {
  id     String @id @default(cuid())
  status String @default("OPEN") // OPEN | CLOSED

  user   User   @relation(fields: [userId], references: [id])
  userId String @unique // one thread per user

  messages SupportMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("support_threads")
}

model SupportMessage {
  id         String @id @default(cuid())
  body       String
  fromAdmin  Boolean @default(false) // false = from user, true = admin reply

  thread   SupportThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  threadId String

  sender   User   @relation(fields: [senderId], references: [id])
  senderId String

  senderName String // denormalized for quick display

  createdAt DateTime @default(now())

  @@index([threadId, createdAt])
  @@map("support_messages")
}

// ── API Key (ERP / machine-to-machine) ───────────────────────────────────────
// Keys use the prefix "b3_live_" + 40 random hex chars.
// Only the SHA-256 hash is stored; the plaintext is shown once at creation.

model ApiKey {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  label      String   // Human-readable name ("Jumis sync", "SAP connector")
  keyHash    String   @unique // SHA-256 of the full key (hex)
  keyPrefix  String   // First 12 chars of the full key — shown in management UI

  // Access scopes (whitelist — empty = no access)
  scopes     String[] // e.g. ["orders:read", "invoices:read", "transport:read", "orders:write"]

  lastUsedAt DateTime?
  expiresAt  DateTime? // null = never expires
  revokedAt  DateTime? // null = active

  createdAt  DateTime @default(now())
  createdById String  // User ID who created it

  @@index([companyId])
  @@index([keyHash])
  @@map("api_keys")
}

// ── B3 Fields — Site Access Passes ─────────────────────────────────────────────────────

model FieldPass {
  id         String @id @default(cuid())
  passNumber String @unique // FP-2026-00001, auto-generated

  // Ownership
  company     Company @relation(fields: [companyId], references: [id])
  companyId   String
  createdBy   User    @relation(fields: [createdById], references: [id])
  createdById String

  // Contract link — must be ACTIVE isFieldContract=true
  contract   FrameworkContract @relation(fields: [contractId], references: [id])
  contractId String

  // Vehicle
  vehiclePlate String   // plate number of the truck
  driverName   String?  // optional driver name to print on pass

  // Validity window
  validFrom DateTime
  validTo   DateTime

  // Waste / load details
  wasteClassCode   String? // e.g. 17 05 04 (EWC waste code)
  wasteDescription String? // free-text description
  unloadingPoint   String? // area/zone on site (e.g. "Sekcija A")
  estimatedTonnes  Float?  // expected load weight

  // Status & document
  status  FieldPassStatus @default(ACTIVE)
  fileUrl String?          // generated PDF stored in Supabase

  // Optional link to a B3Hub order (if material purchase triggered the pass)
  order   Order?  @relation(fields: [orderId], references: [id])
  orderId String?

  revokedReason String?
  revokedAt     DateTime?

  // Actual weight recorded by gate operator after vehicle weighing
  actualNetTonnes Float?

  weighingSlips WeighingSlip[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([contractId])
  @@index([status])
  @@index([validFrom, validTo])
  @@map("field_passes")
}

// ── B3 Fields — Weighing Slips (gate records) ───────────────────────────────

model WeighingSlip {
  id         String @id @default(cuid())
  slipNumber String @unique // WS-YYYY-NNNNN

  fieldPass   FieldPass @relation(fields: [fieldPassId], references: [id])
  fieldPassId String

  // Weight in tonnes (recorded by gate operator at weigh bridge)
  grossTonnes Float  // incoming gross weight
  tareTonnes  Float  // tare (empty vehicle) weight
  netTonnes   Float  // actual waste/material — gross - tare

  vehiclePlate String  // may differ from pass if substituted
  operatorName String? // gate operator who entered the data

  notes   String?
  fileUrl String? // optional weighing slip PDF

  // Where the weighing was performed — supports dual-weighing (source vs destination)
  weighingPoint WeighingPoint @default(LOADING)

  voidedAt     DateTime? // set when this slip is invalidated
  voidedReason String?

  recordedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([fieldPassId])
  @@index([slipNumber])
  @@map("weighing_slips")
}

enum WeighingPoint {
  LOADING   // Svēršana pie piegādātāja (karjers / avots)
  UNLOADING // Svēršana pie saņēmēja (būvlaukums / galamērķis)
}

// ── B3 Fields — Fulfillment type ─────────────────────────────────────────────
enum OrderFulfillmentType {
  DELIVERY // Standard delivery to buyer's site address
  PICKUP   // Self-collect at a B3 Field physical location
}

// ── B3 Fields — Services offered at a physical location ──────────────────────
enum B3FieldService {
  MATERIAL_PICKUP  // Self-collect materials
  WASTE_DISPOSAL   // Bring your own waste
  TRAILER_RENTAL   // Rent a trailer
}

// ── B3 Fields — Physical fulfillment locations ───────────────────────────────
model B3Field {
  id   String @id @default(cuid())
  name String // e.g. "B3 Field Gulbene"
  slug String @unique // e.g. "gulbene" — used in URLs

  // Location
  address    String
  city       String
  postalCode String
  lat        Float
  lng        Float

  // Services available at this location
  services B3FieldService[]

  // Opening hours — { monday: { open: "07:00", close: "19:00" }, ... null = closed }
  openingHours Json

  // Optional link to a RecyclingCenter (same physical site)
  recyclingCenter   RecyclingCenter? @relation(fields: [recyclingCenterId], references: [id])
  recyclingCenterId String?          @unique

  // Operational
  active Boolean @default(true)
  notes  String? // internal notes for gate operators

  // Relations
  orders         Order[]
  pickupSlots    PickupSlot[]
  inventoryItems B3FieldInventoryItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
  @@map("b3_fields")
}

// ── Platform Settings — global key/value config store ────────────────────────
model PlatformSetting {
  key       String   @id            // e.g. "jumis.apiUrl", "bis.enabled"
  value     String                  // always stored as string; booleans use "true"/"false"
  updatedAt DateTime @updatedAt
  updatedBy String?                 // admin userId who last changed this

  @@map("platform_settings")
}

// ── B3 Fields — Inventory items (materials in stock at this location) ─────────
model B3FieldInventoryItem {
  id      String  @id @default(cuid())
  field   B3Field @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  fieldId String

  name         String  // e.g. "Grants 0-32mm", "Smilts smalka"
  unit         String  // e.g. "t", "m³", "gab."
  pricePerUnit Float   // EUR per unit
  stockQty     Float   @default(0)  // current quantity in stock
  minStockQty  Float   @default(0)  // low-stock alert threshold
  available    Boolean @default(true)
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fieldId])
  @@map("b3_field_inventory_items")
}

// ── B3 Fields — Pickup time slots ────────────────────────────────────────────
model PickupSlot {
  id      String @id @default(cuid())
  field   B3Field @relation(fields: [fieldId], references: [id])
  fieldId String

  slotStart  DateTime
  slotEnd    DateTime
  capacity   Int @default(4)  // max vehicles per slot
  booked     Int @default(0)  // current bookings

  // Orders booked into this slot
  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fieldId, slotStart])
  @@map("pickup_slots")
}

// ── B3 Construction — Digitisation layer ─────────────────────────────────────

// Cost-code categories (WBS level 1) — same across every project so costs are comparable.
enum CostCode {
  LABOUR        // Workers / operators (h)
  EQUIPMENT     // Machines / plant hired in (h or day)
  MATERIAL      // Sand, gravel, concrete, etc. (t or m3)
  TRANSPORT     // Trucks, freight (km or load)
  SUBCONTRACTOR // External trade contractors (lump or h)
  OTHER
}

enum DailyReportStatus {
  DRAFT
  SUBMITTED
  APPROVED
}

// Controlled unit-of-measure vocabulary — prevents "m3" vs "m³" vs "kubikmetri" divergence.
// Used on MaterialRateEntry.unit and DailyReportLine.unit so aggregations are always consistent.
enum UnitOfMeasure {
  T       // tonne
  M3      // cubic metre
  M2      // square metre
  M       // linear metre
  H       // hour
  DAY     // shift / working day
  KM      // kilometre
  LOAD    // truck load
  PC      // piece / gab
}

// Grouping for the rate library — mirrors CostCode but is independent so rates can span codes.
enum RateCategory {
  MATERIAL      // Sand, gravel, concrete, aggregates
  TRANSPORT     // Trucks, freight, haulage
  LABOUR        // Workers, operators, foremen
  EQUIPMENT     // Plant, machinery, tools
  SUBCONTRACTOR // External trade contractors
  OTHER
}

// ─── Material Rate Library ────────────────────────────────────────────────────
// Versioned, effective-dated rates — one row per material × supplier × truck config × zone.
// Replaces the annual price spreadsheet.  Admin creates/updates rows; DPR lines reference them.
model MaterialRateEntry {
  id String @id @default(cuid())

  // What
  name        String        // e.g. "FR Šķemba 20-40"
  unit        UnitOfMeasure // controlled vocabulary — no free-text drift
  category    RateCategory  // controlled grouping — mirrors CostCode

  // Who supplies it
  supplierName String
  supplierNote String? // e.g. "DSG karjeri Saikava"

  // Rates
  pricePerUnit      Float   // ex-works / base price
  deliveryFee       Float   @default(0)   // per unit delivery surcharge
  selfCostPerUnit   Float?  // pašizmaksa (optional — hides from foreman view)

  // Density / conversion
  densityCoeff      Float?  // tonne→m3 multiplier (e.g. 1.45 for gravel)

  // Truck configuration context (optional — documents which truck config this applies to)
  truckConfig       String? // e.g. "Vanna 27t", "KG7797+Piekabe 34.5t"

  // Delivery zone
  zone              String? // e.g. "Viestura iela 2, Gulbene"

  // Versioning
  effectiveFrom     DateTime @default(now())
  effectiveTo       DateTime? // null = currently active
  notes             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Back-references
  reportLines    DailyReportLine[]
  templateLines  DprTemplateLine[]
  employees      ConstructionEmployee[]
  budgetLines    ProjectBudgetLine[]

  @@index([category])
  @@index([effectiveFrom])
  @@map("material_rate_entries")
}

// ─── Daily Production Report (DPR) ───────────────────────────────────────────
// One header per site-day.  Foreman logs what happened; admin approves.
model DailyReport {
  id          String @id @default(cuid())

  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String

  createdBy   User    @relation("DprCreatedBy", fields: [createdById], references: [id])
  createdById String

  approvedBy    User?   @relation("DprApprovedBy", fields: [approvedById], references: [id])
  approvedById  String?

  // When / where
  reportDate  DateTime
  siteLabel   String?   // e.g. "Daugmale" — free text, matches ProjectSite.label

  // Narrative
  weatherNote String?
  notes       String?

  status DailyReportStatus @default(DRAFT)

  // Lines
  lines DailyReportLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, reportDate])
  @@map("daily_reports")
}

// ─── Daily Report Line ────────────────────────────────────────────────────────
// One line per resource entry on a DPR.
model DailyReportLine {
  id String @id @default(cuid())

  report    DailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  reportId  String

  // Cost classification
  costCode  CostCode

  // Resource description
  description String  // e.g. "Jānis Kusiņš", "CAT 317", "FR Šķemba 20-40"
  personName  String? // for LABOUR lines — name of worker/driver

  // Quantity × rate → total
  quantity    Float
  unit        UnitOfMeasure // controlled vocabulary — must match rate entry
  unitRate    Float
  total       Float   // stored denormalised for fast reporting

  // Optional link to the rate library (so future rate changes don't corrupt history)
  rateEntryId String?
  rateEntry   MaterialRateEntry? @relation(fields: [rateEntryId], references: [id])

  // Optional link to the employee roster (define once, pick in DPR)
  employeeId String?
  employee   ConstructionEmployee? @relation(fields: [employeeId], references: [id])

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reportId])
  @@index([costCode])
  @@map("daily_report_lines")
}

// ─── Construction Employee Roster ─────────────────────────────────────────────
// Internal B3 Construction staff — defined once, picked in DPR lines.
// These are workers who may not have a platform login.
// Foremen and office staff who use the app are Users (ADMIN); field workers are here.
model ConstructionEmployee {
  id           String  @id @default(cuid())
  firstName    String
  lastName     String
  role         String  // e.g. "Ekskavātora operators", "Strādnieks", "Šoferis"
  personalCode String? // Latvian personal ID (personas kods) — optional, for HR/contracts
  phone        String?
  email        String?
  notes        String?

  // Default hourly / unit rate — pulled from the rate library when picked in DPR
  defaultRateEntryId String?
  defaultRateEntry   MaterialRateEntry? @relation(fields: [defaultRateEntryId], references: [id])

  active Boolean @default(true)

  // Back-ref: every DPR line that references this person
  reportLines   DailyReportLine[]
  templateLines DprTemplateLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
  @@map("construction_employees")
}

// ─── DPR Template ─────────────────────────────────────────────────────────────
// Recurring daily cost templates — foreman picks a template, all lines are
// pre-populated into the DPR.  Replaces entering the same 5-6 rows every day.
// Templates are global (shared across projects) or pinned to a project.
model DprTemplate {
  id          String  @id @default(cuid())
  name        String  // e.g. "Daugmale — standarta diena", "Gulbene rīti"
  description String?

  // Optional: pin to a specific project (null = global template)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  active Boolean @default(true)

  lines DprTemplateLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@map("dpr_templates")
}

model DprTemplateLine {
  id         String @id @default(cuid())
  template   DprTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId String

  costCode    CostCode
  description String
  quantity    Float
  unit        UnitOfMeasure
  unitRate    Float

  // Optional links to rate library / employee roster (auto-fill)
  rateEntryId String?
  rateEntry   MaterialRateEntry? @relation(fields: [rateEntryId], references: [id])

  employeeId String?
  employee   ConstructionEmployee? @relation(fields: [employeeId], references: [id])

  notes       String?
  sortOrder   Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([templateId])
  @@map("dpr_template_lines")
}

// ─── Project Sub-Budget (per cost code) ──────────────────────────────────────
// Breaks the single budgetAmount into per-cost-code allocations.
// e.g. Labour €8,000 | Equipment €12,000 | Transport €3,000 | Materials €5,000
// Enables burn % per category in the profitability view.
model ProjectBudgetLine {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  costCode    CostCode
  description String        @default("")
  quantity    Float         @default(1)
  unit        UnitOfMeasure @default(H)
  unitRate    Float         @default(0)
  amount      Float         @default(0) // stored = quantity × unitRate

  // Optional link to rate library entry (for B3Hub price lookup)
  rateEntryId String?
  rateEntry   MaterialRateEntry? @relation(fields: [rateEntryId], references: [id])

  sortOrder Int     @default(0)
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // No unique constraint — multiple lines per cost code are allowed
  @@index([projectId])
  @@index([projectId, costCode])
  @@map("project_budget_lines")
}

// ─── Construction Subcontractor ───────────────────────────────────────────────
// External companies or sole traders that B3 Construction hires to assist with
// specific tasks (excavation, concrete, electrical, etc.).
// Each subcontractor can have multiple engagements (contracts) per project.
model ConstructionSubcontractor {
  id              String  @id @default(cuid())
  name            String                 // Company name or sole trader name
  registrationNo  String?                // LV company reg no (optional)
  contactPerson   String?
  phone           String?
  email           String?
  speciality      String?                // e.g. "Ekskavācija", "Betonēšana"
  notes           String?
  active          Boolean @default(true)

  engagements SubcontractorEngagement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
  @@map("construction_subcontractors")
}

// One engagement = one sub-contract within a project
model SubcontractorEngagement {
  id             String                     @id @default(cuid())
  subcontractor  ConstructionSubcontractor  @relation(fields: [subcontractorId], references: [id])
  subcontractorId String
  project        Project                    @relation(fields: [projectId], references: [id])
  projectId      String

  description    String                     // What work was agreed
  agreedAmount   Float                      // Contract price
  invoicedAmount Float?                     // What they actually invoiced
  paidAmount     Float?                     // What we've paid
  startDate      DateTime?
  endDate        DateTime?
  status         SubEngagementStatus        @default(ACTIVE)
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([subcontractorId])
  @@map("subcontractor_engagements")
}

enum SubEngagementStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

// ─── Construction Client Invoice ──────────────────────────────────────────────
// Invoices issued BY B3 Construction TO their clients.
// Tracks what has been billed and what has been paid, per project.
model ConstructionClientInvoice {
  id          String  @id @default(cuid())
  project     Project @relation(fields: [projectId], references: [id])
  projectId   String

  invoiceNo   String                        // B3 Construction's own invoice number
  issueDate   DateTime
  dueDate     DateTime?
  amount      Float                         // Invoice amount incl. VAT
  vatAmount   Float?                        // VAT portion
  description String?                       // What work this covers
  status      ClientInvoiceStatus           @default(ISSUED)
  paidAt      DateTime?
  paidAmount  Float?                        // Can be partial
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@map("construction_client_invoices")
}

enum ClientInvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}
