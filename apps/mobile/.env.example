# B3Hub Mobile - environment variables
# Copy to .env.local and fill in real values.
# In EAS builds, set these as EAS environment secrets instead.
# NEVER commit .env.local with real secrets.

# Google Maps API key
# Get from: https://console.cloud.google.com/google/maps-apis/credentials
# Required APIs to enable on your key:
#   - Maps SDK for iOS
#   - Maps SDK for Android
#   - Places API           (AddressPicker autocomplete)
#   - Geocoding API        (reverse geocode drag pin -> address)
#   - Routes API v2        (road polylines + distance/ETA in JobRouteMap)
#   - Route Optimization API (multi-stop driver planning)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
EXPO_PUBLIC_GOOGLE_MAPS_KEY=

# Production backend URL. In dev, falls back to localhost:3000.
# For real device testing (not simulator), set this to your local IP:
#   EXPO_PUBLIC_API_URL=http://192.168.x.x:3000/api/v1
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1

# Stripe publishable key (pk_test_* for dev, pk_live_* for production)
# Get from: https://dashboard.stripe.com/apikeys
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# EAS project ID — from `eas init` (runs once, stored in app.config.ts)
# Get from: https://expo.dev/accounts/[your-account]/projects/b3hub
EAS_PROJECT_ID=
