{
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "jsx": "react-native",
    "lib": ["dom", "esnext"],
    "moduleResolution": "bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "target": "ESNext",
    "strict": true,
    "paths": {
      "@/*": ["./*"],
      "@b3hub/shared": ["../../packages/shared/src/index.ts"]
    }
  },
  "extends": "expo/tsconfig.base",
  "exclude": ["node_modules", "*.js", "*.mjs"]
}
